[sub_resource type="GDScript" id="GDScript_hbgqb"]
script/source = "@tool
extends RiveRaw

func _ready() -> void:
	draw_rive.connect(_on_draw_rive)

var path := RivePath.new()
var paint := RivePaint.new()

func _on_draw_rive(renderer: RiveRendererWrapper) -> void:
	return
	
	path.set_fill_rule(2)
	
	var arr = [Vector2(0,0), Vector2(100,0), Vector2(70,100), Vector2(0,100)]
	path.add_poly(arr, false)
	
	arr = [Vector2(20,20), Vector2(50,20), Vector2(20,50)]
	arr.reverse()
	
	path.add_poly(arr, false)
	
	renderer.draw_path(path, paint)
	
	path.reset()
	path.set_fill_rule(2)
	
	#path.add_poly([Vector2(20,20), Vector2(0,100), Vector2(0,100)], true)
	
	#renderer.draw_path(path, paint)
"

[sub_resource type="GDScript" id="GDScript_brmve"]
script/source = "@tool
extends Node2D

var points : Array[Vector3]

func _input(event: InputEvent) -> void:
	if event is InputEventMouseButton:
		if event.pressed:
			get_parent().show_preview = true
		else:
			get_parent().commit()
			points.clear()
			
			get_parent().show_preview = false
	
	if event is InputEventMouseMotion:
		if event.button_mask == MOUSE_BUTTON_MASK_LEFT:
			var p : Vector2 = event.position
			
			var prev_p : Vector3
			
			#if not points.is_empty():
				#prev_p = points.back()
			#else:
				#prev_p = Vector3(p.x, p.y, 1)
			#
			#if not points.is_empty():
				#points.append(prev_p)
				#points.append(prev_p)
			#else:
				#points.append(Vector3(p.x, p.y, 1))
				#points.append(Vector3(p.x, p.y, 1))
			
			#points.append(Vector3(p.x, p.y, 1))
			#points.append(Vector3(p.x, p.y, 1))
			
			points.append(Vector3(p.x, p.y, 1))
			
			get_parent().set_stroke_points(points)

func _ready() -> void:
	get_parent().stroke_commited.connect(_on_stroke_commited)
	
	%RiveRaw.draw_rive.connect(_on_rive_draw)

func _process(delta: float) -> void:
	if %RiveCanvas2D.size != get_lash_canvas().size:
		%RiveCanvas2D.size = get_lash_canvas().size
		get_parent().render_target_instance.size = %RiveCanvas2D.size

var commited_paths : Array[PackedVector2Array]
func _on_stroke_commited(paths:Array[PackedVector2Array]) -> void:
	print(\"Commited stroke!\")
	
	#print(paths)
	
	print(\"There are %s paths!\" % [paths.size()])
	
	if paths.is_empty():
		return
	
	var view_matrix := get_world_to_screen_matrix()
	for path in paths:
		for i in range(0, path.size()):
			path[i] = view_matrix.affine_inverse() * path[i]
	
	commited_paths.append_array(paths)
	
	#for path in paths:
		#print(\"Clockwise: \", Geometry2D.is_polygon_clockwise(path))
	
	#var polygons : Array[PackedVector2Array]
	#polygons = merge_polygons_with_polygons(polygons, paths)
	#polygons = [paths[0]]
	
	
	
	#
	#for path in polygons:
		#var polygon := Polygon2D.new()
		#polygon.antialiased = true
		#polygon.polygon = path
		#add_child(polygon)
 
func get_lash_canvas() -> LashCanvas:
	return get_parent().get_parent().get_parent().get_parent().get_parent()

func get_world_to_screen_matrix() -> Transform2D:
	var canvas_camera : LashCanvasCamera = get_lash_canvas().camera
	return canvas_camera.get_screen_matrix() * canvas_camera.get_view_matrix()

var rive_path := RivePath.new()
var rive_paint := RivePaint.new()
func _on_rive_draw(renderer: RiveRendererWrapper) -> void:
	renderer.save()
	
	rive_path.reset()
	
	var canvas_camera : LashCanvasCamera = get_lash_canvas().camera
	
	var view_matrix := get_world_to_screen_matrix()
	renderer.transform(view_matrix.x.x, view_matrix.x.y, view_matrix.y.x, view_matrix.y.y, view_matrix.origin.x, view_matrix.origin.y)

	for path in commited_paths:
		for i in range(0, path.size()-4, 4):
			var p0 := path[i+0]
			var p3 := path[i+3]
			var p1 := path[i+1]
			var p2 := path[i+2]
			
			if i == 0:
				rive_path.move_to(p0.x, p0.y)
				continue
			
			rive_path.cubic_to(p1.x, p1.y, p2.x, p2.y, p3.x, p3.y)
	
	rive_path.set_fill_rule(2)
	rive_paint.set_style(1)
	rive_paint.set_color(Color.BLACK)
	
	renderer.draw_path(rive_path, rive_paint)
	
	rive_paint.set_style(0)
	rive_paint.set_color(Color.GREEN)
	
	#renderer.draw_path(rive_path, rive_paint)
	
	renderer.restore()

func merge_polygons_with_polygons(a:Array[PackedVector2Array], b:Array[PackedVector2Array]) -> Array[PackedVector2Array]:
	var result : Array[PackedVector2Array]
	
	for polygon_a in a:
		for polygon_b in b:
			result.append_array(Geometry2D.merge_polygons(polygon_a, polygon_b))
	
	return result
"

